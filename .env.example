POSTGRES_DB=book_designer
POSTGRES_USER=book_user
POSTGRES_PASSWORD=book_password
DATABASE_URL=postgresql+psycopg2://book_user:book_password@db:5432/book_designer
LLM_PROVIDER=mock
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=220
OLLAMA_KEEP_ALIVE=5m
OLLAMA_STREAM=false
LLM_TWO_PASS_ENABLED=false
LLM_FAST_MODE=true
OLLAMA_WARMUP_ENABLED=true
OLLAMA_WARMUP_TIMEOUT_SECONDS=300
DEFAULT_LLM_MODEL=
FICTION_LLM_MODEL=
MARKETING_LLM_MODEL=
FINANCE_LLM_MODEL=
GENERAL_LLM_MODEL=
QUALITY_LLM_MODEL=
SERVER_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Hugging Face provider
HF_API_TOKEN=
HF_BASE_URL=https://api-inference.huggingface.co/models
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_TIMEOUT_SECONDS=90
HF_MAX_NEW_TOKENS=320
HF_RETRY_ATTEMPTS=3
HF_RETRY_BACKOFF_SECONDS=1.0
HF_CHAT_TEMPLATE=plain
